{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Biomarker Finder",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "--disease", "diabetes mellitus",
                "--datasets", "3",
                "--top-biomarkers", "20"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Run: Coronary Artery Disease",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "--disease", "coronary artery disease",
                "--datasets", "2"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Run: Breast Cancer",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "--disease", "breast cancer",
                "--datasets", "3",
                "--logfc", "1.5"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
