# ─────────────────────────────────────────────────────────────
#  AI Clinical Biomarker Finder — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── NCBI / Entrez (required) ───────────────────────────────
# Register free at https://www.ncbi.nlm.nih.gov/account/
NCBI_EMAIL=your_email@example.com
# Optional but strongly recommended — raises rate limit from 3→10 req/sec
# Get one free at https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=your_ncbi_api_key_here

# ── Ollama (local LLM for literature analysis) ─────────────
# Install Ollama: https://ollama.com/
# Then pull a model:  ollama pull deepseek-r1
#                 or: ollama pull llama3
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-r1

# ── Output directories (optional — defaults shown) ────────
OUTPUT_DIR=./outputs
REPORTS_DIR=./reports
DATA_DIR=./data

# ── Job retention (seconds before completed jobs are cleared)
JOB_RETENTION_SECONDS=3600
