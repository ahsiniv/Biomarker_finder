# NCBI API Key (optional but recommended - get from https://www.ncbi.nlm.nih.gov/account/)
NCBI_API_KEY=

# Email for NCBI Entrez (required by NCBI)
NCBI_EMAIL=you@example.com

# Output directories (can be left as defaults)
OUTPUT_DIR=./outputs
REPORTS_DIR=./reports
DATA_DIR=./data

# (Optional) Fix SSL certificate verification issues for NCBI GEO on some systems
# SSL_CERT_FILE=.venv/Lib/site-packages/certifi/cacert.pem

# Ollama settings (for LLM literature mining)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-r1
